{
  "name": "vabeachcast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run budget",
    "budget": "node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "screenshots:release": "CAPTURE_RELEASE_SCREENSHOTS=1 playwright test e2e/release-screenshots.spec.ts --project=chromium",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "smoke:deployment": "node scripts/deployment-smoke.mjs",
    "smoke:live": "node scripts/live-provider-smoke.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.19.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "16.5.0",
    "jsdom": "26.1.0",
    "prettier": "3.9.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.1",
    "vite": "7.3.6",
    "vitest": "3.2.6"
  }
}
